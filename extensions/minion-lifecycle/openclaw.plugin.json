{
  "id": "minion-lifecycle",
  "name": "Minion Lifecycle",
  "version": "3.3.0",
  "description": "Auto-posts sub-agent spawn, completion, and progress events to Discord webhook",
  "main": "index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean" },
      "webhookUrl": { "type": "string" },
      "agentLabel": { "type": "string" },
      "progressPollMs": { "type": "number", "default": 15000 },
      "errorMention": { "type": "string" },
      "retryMax": { "type": "number", "default": 5 },
      "retryBaseMs": { "type": "number", "default": 1500 },
      "retryJitterMs": { "type": "number", "default": 400 }
    }
  },
  "config": {
    "enabled": true
  }
}
